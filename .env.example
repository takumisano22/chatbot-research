# RAG 実験バッチ（docker compose run experiment_runner）用。
# リポジトリルートに `.env` としてコピーし、ホスト環境に合わせて編集する。

# --- アプリ ---
APP_ENV=development

# --- LLM（Docker から Windows ホストの Ollama 等へ）---
LLM_PROVIDER=ollama
LLM_ADAPTER_SUBPACKAGE=ollama
LLM_API_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.5
LLM_REQUEST_TIMEOUT_SECONDS=600

# --- Embedding ---
EMBEDDING_PROVIDER=ruri_http
EMBEDDING_BASE_URL=http://host.docker.internal:8010
EMBEDDING_MODEL=cl-nagoya/ruri-v3-310m

# --- Langfuse（無効にする場合は LANGFUSE_ENABLED=false）---
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST=http://host.docker.internal:3000
LANGFUSE_ENVIRONMENT=development

# --- Chroma（compose の vector_store サービス名で名前解決）---
VECTOR_STORE_PROVIDER=chroma
VECTOR_DB_ADAPTER_SUBPACKAGE=chroma
VECTOR_STORE_SERVER_HOST=vector_store
VECTOR_STORE_SERVER_PORT=8000
# HTTP 接続時は Chroma サーバ側の永続化を使う。ローカル埋め込み Chroma（SERVER_HOST 空）のときに参照される。
VECTOR_STORE_PERSIST_DIR=data/vector_store
RAG_COLLECTION_NAME=rag_documents

# 検索・チャンクの既定（research_pair で top_k 等を上書きする前提のフォールバック）
RAG_TOP_K=4
RAG_VECTOR_TOP_K=4
RAG_KEYWORD_WEIGHT=0.5
RAG_CHUNK_SIZE=400
RAG_CHUNK_OVERLAP=50

# --- PDF 取り込み（実験バッチの PDF 変換パイプライン）---
PDF_EXTRACTION_MODE=auto
PDF_OCR_AUTO_MIN_CHARS_PER_PAGE=50
PDF_OCR_LANG=jpn+eng
PDF_OCR_OEM=3
PDF_OCR_PSM=3
PDF_OCR_DPI=300
PDF_OCR_PREPROCESS=true

# --- 実験用ディレクトリ（コンテナでは /app 直下にマウント）---
# EXPERIMENT_RESEARCH_PAIRS_DIR=research_pairs
# EXPERIMENT_QA_DATASETS_DIR=qa_datasets
# EXPERIMENT_INGEST_DOCUMENT_DIR=ingest_document
# EXPERIMENT_OUTPUTS_DIR=outputs
