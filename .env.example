# [bolt-002 P1 Docker Compose] このファイル（およびコピーした .env）がアプリ設定の正。Compose は env_file でコンテナに渡すだけ。
# Docker の公開ポート（8000 / 8501 / 5432）は compose.yaml に固定。変えたい場合は compose.yaml を編集し、.env の URL / CORS も揃える。

# --- アプリ共通 ---
APP_ENV=development
LOG_LEVEL=INFO

API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://localhost:8010,http://127.0.0.1:8010

# --- LLM（プロバイダ: LLM_PROVIDER。現状 ollama のみ実装）---
LLM_PROVIDER=ollama
# llm_provider.<名前> の import 先（論理 LLM_PROVIDER とは別。同じ LlmHttpChatParams / build_compatible_chat_model API の実装差し替え）
LLM_ADAPTER_SUBPACKAGE=ollama
# HTTP で到達するチャット API のベース URL（Docker からホストのローカルサーバへは host.docker.internal）
LLM_API_BASE_URL=http://host.docker.internal:11434
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.5
# LLM への HTTP タイムアウト（秒）。Streamlit のチャット POST はこれより少し長めに取る。
LLM_REQUEST_TIMEOUT_SECONDS=600

# --- Embedding（EMBEDDING_PROVIDER = ollama | ruri_http。EMBEDDING_BASE_URL / EMBEDDING_MODEL）---
# EMBEDDING_PROVIDER=ollama
# EMBEDDING_BASE_URL=http://host.docker.internal:11434
# EMBEDDING_MODEL=nomic-embed-text
# compose の ruri-embed（sentence-transformers / HF）を HTTP で使う。model は ruri 側 EMBEDDING_MODEL と一致させる
EMBEDDING_PROVIDER=ruri_http
EMBEDDING_BASE_URL=http://host.docker.internal:8010
EMBEDDING_MODEL=cl-nagoya/ruri-v3-310m

# --- OpenAI 互換 API（任意）---
# OPENAI_COMPATIBLE_BASE_URL=
# OPENAI_COMPATIBLE_API_KEY=
# OPENAI_COMPATIBLE_MODEL=

# --- AWS Bedrock（P4 以降）---
# AWS_REGION=ap-northeast-1
# BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20240620-v1:0
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=

# --- Langfuse（P3 以降）---
LANGFUSE_ENABLED=true
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_HOST="http://host.docker.internal:3000"
LANGFUSE_ENVIRONMENT=development

# --- RDB（[bolt-003 フェーズC] SQLAlchemy 非同期 ORM。接続は DATABASE_URL のみ）---
# DB_* は compose の postgres が公式イメージ向けに POSTGRES_* へ写す。値は DATABASE_URL のユーザー・パスワード・DB 名と一致させる。
# アプリ・Alembic（init）は DATABASE_URL だけを読む（POSTGRES_* は .env に書かない）。
DB_USER=user
DB_PASSWORD=app
DB_NAME=app_db
# ホスト名は compose の DB サービス名 postgres（ポートは compose の 5432 公開に合わせる）
DATABASE_URL=postgresql+asyncpg://user:app@postgres:5432/app_db
# RAG PDF 非同期取り込み（ingest_worker）は同一 DATABASE_URL でジョブ行を共有する。
# スキーマ作成: Compose の init が `init/run.sh` で `alembic upgrade head` を 1 回実行する（RDS でも同手順を想定）。


# --- RAG（bolt-004 フェーズ0: キーワード検索・vector DB）---
# 利用するベクトルストア実装（現状は次の値のみ。.env ではこの行だけ実装名を書く想定）
# Docker: ベクトルDBの名前付きボリュームは `${VECTOR_STORE_PROVIDER}_data` になる（compose の name 展開）
VECTOR_STORE_PROVIDER=chroma
# vectordb.<名前> の import 先（接続先・VECTOR_STORE_PROVIDER とは別）
VECTOR_DB_ADAPTER_SUBPACKAGE=chroma
# compose の vector_store サービスへ HTTP（サービス名 = ホスト名）
VECTOR_STORE_SERVER_HOST=vector_store
VECTOR_STORE_SERVER_PORT=8000
RAG_COLLECTION_NAME=rag_documents

RAG_TOP_K=4  # キーワード検索で集めるチャンク数の上限（API で k を省略した keyword モードの既定）
RAG_VECTOR_TOP_K=4  # ベクトル検索の件数上限（API で k を省略した vector / hybrid の vector 側の既定）
RAG_KEYWORD_WEIGHT=0.5  # キーワード類似度スコアに掛ける重み（0〜1。検索結果の並びに効く）
# hybrid_search 窓口の委譲先（将来の統合実装まで vector か keyword に振る）
RAG_HYBRID_DELEGATE=vector_search

RAG_CHUNK_SIZE=400  # 取り込み時に文書を分割するチャンク長（固定長）
RAG_CHUNK_OVERLAP=50  # 隣接チャンク間で重ねる文字数（境界で文脈が切れないようにする）

# --- RAG PDF / txt・md（bolt-004: 取り込み上限。PDF 本文は MarkItDown）---

RAG_PDF_MAX_FILES_PER_REQUEST=30  # 1 リクエストあたりの PDF 数上限
RAG_PDF_MAX_BYTES_PER_FILE=26214400  # 1 ファイルあたりのバイト上限（例は 25MiB 相当）

PDF_EXTRACTION_MODE=auto  # native / ocr / auto
PDF_OCR_AUTO_MIN_CHARS_PER_PAGE=50  # auto 時に OCR に切り替える閾値（1ページ当たり）
PDF_OCR_LANG=jpn+eng  # Tesseract 言語（例: eng, jpn, jpn+eng）
# OEM: 使う認識エンジン種別（通常は 3=自動選択）、PSM: ページレイアウト仮定（通常文書は 3）
PDF_OCR_OEM=3  # Tesseract OCR Engine Mode
PDF_OCR_PSM=3  # Tesseract Page Segmentation Mode
PDF_OCR_DPI=300  # PDF→画像変換 DPI
PDF_OCR_PREPROCESS=true  # OCR 前処理（グレー化・傾き補正・二値化）

RAG_TEXT_MD_MAX_FILES_PER_REQUEST=30  # txt/md キュー・同期アップロードのファイル数上限
RAG_TEXT_MD_MAX_BYTES_PER_FILE=26214400  # 同上の 1 ファイルバイト上限

# --- Streamlit → API ---
# [bolt-002 P1 Docker Compose] Compose 上では API サービス名 backend・ポート 8000 固定
#STREAMLIT_API_BASE_URL=http://backend:8000

# --- Next.js（Docker ビルド時のクライアント向け API オリジン）---
# ブラウザがホストの compose 公開ポートから API に届ける URL（末尾スラッシュなし）。ビルド引数として frontend イメージに渡る。
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_LLM_REQUEST_TIMEOUT_SECONDS=600

# --- 実験バッチ API（Tailscale 経由のリモート実行想定。無効時はルート未登録）---
# true で /api/v1/experiment/* を有効化。LLM/埋め込みは manifest で一時上書きし、処理後はプロセスの基準設定に戻る。
EXPERIMENT_BATCH_ENABLED=false
# 最終 HTTP リクエストからこの秒数経過後に SIGTERM（任意で EXPERIMENT_IDLE_STOP_SHELL を先に実行）。0 で無効。
EXPERIMENT_IDLE_SHUTDOWN_SECONDS=0
# 例（Linux ホストで docker compose を止める場合。docker.sock と compose ファイルのマウントが別途必要）:
# EXPERIMENT_IDLE_SHUTDOWN_SECONDS=1800
# EXPERIMENT_IDLE_STOP_SHELL=docker compose -f /workspace/compose.yaml stop
# 任意。設定時は GET/POST で Authorization: Bearer <token> を要求。
# EXPERIMENT_API_TOKEN=
# 実験 manifest で run_ragas_metrics=true にした場合、RAGAS Faithfulness を計算し Langfuse の experiment.ragas span に載せる。