# 実験ランナー（backend/Dockerfile, context=リポジトリルート）向け。
# COPY 対象は backend/pyproject.toml · backend/app/ · llm_definitions/ · vector_stores/ のソースのみ。
# compose でマウントするディレクトリ・ローカル永続はコンテキストに含めない。

# --- 秘密・ローカル環境 ---
.env
.env.local
.env.*.local

# --- compose マウント先（イメージビルド不要・コンテキスト肥大化の主因）---
ingest_document/
research_pairs/
qa_datasets/
outputs/

# --- このリポジトリ内の別サービス（実験イメージの依存に含まれない）---
ruri-embed-service/

# --- エディタ・ローカル AI（ビルド無関係）---
.cursor/
.cursorignore
agent-transcripts/
mcps/
.idea/
.vscode/

# --- Python 仮想環境・ロック（イメージ内で pip install する）---
**/.venv/
venv/
**/uv.lock

# --- バイトコード・キャッシュ・テスト・型検査 ---
**/__pycache__/
*.py[cod]
.pytest_cache/
**/.pytest_cache/
**/.mypy_cache/
**/.ruff_cache/
.hypothesis/
**/.hypothesis/
**/.ipynb_checkpoints/
**/.benchmarks/
.dmypy.json
dmypy.json

# --- パッケージング成果物（ホストで pip install した残骸）---
**/*.egg-info/
**/build/
**/dist/
**/.eggs/
*.whl

# --- カバレッジ・ツール ---
.coverage
.coverage.*
coverage.xml
htmlcov/
.tox/
.nox/

# --- ログ・ローカルデータ・ベクトルストア ---
*.log
logs/
data/
**/.chroma/
**/*.sqlite3

# --- その他ホスト専用 ---
**/.streamlit/
.direnv/
.envrc
docker-compose.override.yml

# --- 鍵（誤送信防止）---
*.pem
*.key
id_rsa
id_rsa.pub
*.p12

# --- OS ごみ ---
**/.DS_Store
**/Thumbs.db
**/desktop.ini
*.swp
*~

# --- Git / CI / ドキュメント / テスト（ランタイム不要）---
.git/
.github/
.gitattributes
docs/
backend/tests/
prompts/
# 旧フロント（リポジトリに無くてもパターンのみ残すコストは低い）
frontend_streamlit/
frontend_nextjs/

# --- Compose 定義（デーモンがホスト側で読む。コンテキスト省略可）---
compose.yaml
compose.*.yaml
docker-compose*.yaml

# --- リポジトリメタ ---
.gitignore
.dockerignore
/*.md
LICENSE*
CHANGELOG*
SECURITY.md

# パッケージ内の README（実行に不要）
backend/**/README.md
